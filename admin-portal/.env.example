# Admin Dashboard Environment Variables

# Environment (development, staging, production)
VITE_ENV=development

# API Configuration - Uses domain from global config
VITE_API_BASE_URL=https://api.${DOMAIN_ROOT}

# Domain Configuration - Loaded from global config
VITE_DOMAIN_ROOT=${DOMAIN_ROOT}

# API Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# Admin Authentication
# Note: Admin tokens should be obtained through the authentication flow
# and stored securely (e.g., in httpOnly cookies or secure storage)
