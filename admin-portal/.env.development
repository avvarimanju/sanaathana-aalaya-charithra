# Admin Portal - Local Development Environment
# This connects to the local backend server running on port 4000

# Environment
VITE_ENV=development

# API Configuration - Local Backend
VITE_API_BASE_URL=http://localhost:4000

# API Timeout (milliseconds)
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEBUG_LOGS=true

# Admin User (for development only)
# In production, this will be handled by Cognito
VITE_DEFAULT_ADMIN_ID=local-admin
