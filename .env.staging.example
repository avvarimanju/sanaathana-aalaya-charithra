# Staging Environment Configuration

# Environment
STAGE=staging
NODE_ENV=production

# AWS Configuration
AWS_REGION=ap-south-1  # Mumbai region for optimal performance in India
CDK_DEFAULT_REGION=ap-south-1

# DynamoDB Tables (will be prefixed with 'staging-')
HERITAGE_SITES_TABLE=staging-HeritageSites
ARTIFACTS_TABLE=staging-Artifacts
TEMPLE_GROUPS_TABLE=staging-TempleGroups
PRICE_CONFIGURATIONS_TABLE=staging-PriceConfigurations
PURCHASES_TABLE=staging-Purchases
CONTENT_CACHE_TABLE=staging-ContentCache

# S3 Buckets (will be prefixed with 'staging-')
TEMPLE_IMAGES_BUCKET=staging-temple-images
ARTIFACT_IMAGES_BUCKET=staging-artifact-images
QR_CODES_BUCKET=staging-qr-codes
GENERATED_CONTENT_BUCKET=staging-generated-content

# Cognito (Update after deployment)
USER_POOL_ID=ap-south-1_XXXXXXXXX
USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Bedrock Configuration
BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0  # Cheaper model for staging
BEDROCK_ENABLED=true

# Polly Configuration
POLLY_ENABLED=true

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_MODE=test

# Logging
LOG_LEVEL=debug

# Monitoring
ENABLE_XRAY=false
ENABLE_METRICS=true

# API Configuration
API_THROTTLE_RATE=100
API_THROTTLE_BURST=200
