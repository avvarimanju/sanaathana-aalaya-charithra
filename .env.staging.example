# Staging Environment Configuration
NODE_ENV=staging

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-staging-account-id

# DynamoDB Endpoint - Leave empty for real AWS DynamoDB
# DYNAMODB_ENDPOINT=

# DynamoDB Table Names
TEMPLES_TABLE=Staging-Temples
ARTIFACTS_TABLE=Staging-Artifacts
TEMPLE_GROUPS_TABLE=Staging-TempleGroups
PRICING_TABLE=Staging-Pricing
PRICE_HISTORY_TABLE=Staging-PriceHistory
PRICING_FORMULAS_TABLE=Staging-PricingFormulas
CONTENT_JOBS_TABLE=Staging-ContentJobs
CONTENT_TABLE=Staging-Content
ADMIN_USERS_TABLE=Staging-AdminUsers
MOBILE_USERS_TABLE=Staging-MobileUsers
DEFECTS_TABLE=Staging-Defects
STATE_VISIBILITY_TABLE=Staging-StateVisibility

# S3 Bucket Names
CONTENT_BUCKET=staging-sanaathana-content
ASSETS_BUCKET=staging-sanaathana-assets

# API Configuration
API_URL=https://api-staging.sanaathana.org
ADMIN_PORTAL_URL=https://admin-staging.sanaathana.org
MOBILE_APP_URL=https://app-staging.sanaathana.org

# Feature Flags
ENABLE_AI_CONTENT_GENERATION=true
ENABLE_ANALYTICS=true
ENABLE_CACHING=true

# Logging
LOG_LEVEL=info
