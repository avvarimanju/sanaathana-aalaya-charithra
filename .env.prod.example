# Production Environment Configuration

# Environment
STAGE=prod
NODE_ENV=production

# AWS Configuration
AWS_REGION=ap-south-1  # Mumbai region for optimal performance in India
CDK_DEFAULT_REGION=ap-south-1

# DynamoDB Tables (will be prefixed with 'prod-')
HERITAGE_SITES_TABLE=prod-HeritageSites
ARTIFACTS_TABLE=prod-Artifacts
TEMPLE_GROUPS_TABLE=prod-TempleGroups
PRICE_CONFIGURATIONS_TABLE=prod-PriceConfigurations
PURCHASES_TABLE=prod-Purchases
CONTENT_CACHE_TABLE=prod-ContentCache

# S3 Buckets (will be prefixed with 'prod-')
TEMPLE_IMAGES_BUCKET=prod-temple-images
ARTIFACT_IMAGES_BUCKET=prod-artifact-images
QR_CODES_BUCKET=prod-qr-codes
GENERATED_CONTENT_BUCKET=prod-generated-content

# Cognito (Update after deployment)
USER_POOL_ID=ap-south-1_XXXXXXXXX
USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Bedrock Configuration
BEDROCK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0  # Better model for production
BEDROCK_ENABLED=true

# Polly Configuration
POLLY_ENABLED=true

# Razorpay (Live Mode)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_MODE=live

# Logging
LOG_LEVEL=info

# Monitoring
ENABLE_XRAY=true
ENABLE_METRICS=true

# API Configuration
API_THROTTLE_RATE=1000
API_THROTTLE_BURST=2000

# Security
ENABLE_WAF=true
ENABLE_SHIELD=false  # Optional, additional cost
