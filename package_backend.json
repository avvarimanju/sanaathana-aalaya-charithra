{
  "name": "sanaathana-aalaya-charithra",
  "version": "1.0.0",
  "description": "Sanaathana Aalaya Charithra - AI-Powered Hindu Temple Heritage Platform",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest --runInBand --forceExit --detectOpenHandles --maxWorkers=1",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand --forceExit --maxWorkers=1",
    "cdk": "cdk",
    "deploy": "cdk deploy --all",
    "destroy": "cdk destroy --all",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "bootstrap": "cdk bootstrap",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "bundle": "esbuild src/lambdas/**/*.ts --bundle --platform=node --target=node18 --outdir=dist/lambdas",
    "local:start": "sam local start-api",
    "local:invoke": "sam local invoke",
    "seed": "ts-node scripts/seed-data.ts",
    "quick-deploy": "npm run build && npm run bundle && npm run deploy && npm run seed",
    "pre-generate": "ts-node src/pre-generation/cli.ts",
    "pre-generate:dry-run": "ts-node src/pre-generation/cli.ts --dry-run",
    "pre-generate:force": "ts-node src/pre-generation/cli.ts --force",
    "deploy:pre-generation": "bash scripts/deploy-pre-generation-lambda.sh",
    "deploy:pre-generation:verify": "bash scripts/deploy-pre-generation-lambda.sh --verify-only",
    "reorganize": "ts-node src/reorganizer/cli.ts",
    "reorganize:dry-run": "ts-node src/reorganizer/cli.ts --dry-run"
  },
  "keywords": [
    "aws",
    "heritage",
    "ai",
    "bedrock",
    "polly",
    "lambda",
    "dynamodb",
    "s3",
    "cloudfront",
    "api-gateway"
  ],
  "author": "Sanaathana Aalaya Charithra Team",
  "license": "MIT",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.130",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.9.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "aws-cdk": "^2.108.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.54.0",
    "fast-check": "^4.5.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@aws-cdk/aws-apigatewayv2-alpha": "^2.108.0-alpha.0",
    "@aws-cdk/aws-apigatewayv2-integrations-alpha": "^2.108.0-alpha.0",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.997.0",
    "@aws-sdk/client-bedrock-runtime": "^3.456.0",
    "@aws-sdk/client-cloudwatch": "^3.987.0",
    "@aws-sdk/client-comprehend": "^3.986.0",
    "@aws-sdk/client-dynamodb": "^3.456.0",
    "@aws-sdk/client-lambda": "^3.996.0",
    "@aws-sdk/client-polly": "^3.456.0",
    "@aws-sdk/client-s3": "^3.456.0",
    "@aws-sdk/client-translate": "^3.456.0",
    "@aws-sdk/lib-dynamodb": "^3.456.0",
    "@aws-sdk/s3-request-presigner": "^3.987.0",
    "@aws-sdk/util-dynamodb": "^3.456.0",
    "@types/pdfkit": "^0.17.5",
    "aws-cdk-lib": "^2.108.0",
    "constructs": "^10.3.0",
    "csv-stringify": "^6.6.0",
    "joi": "^17.11.0",
    "pdfkit": "^0.17.2",
    "razorpay": "^2.9.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/index.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  }
}
