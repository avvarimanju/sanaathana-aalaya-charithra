# Production Environment Configuration
NODE_ENV=production

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-production-account-id

# DynamoDB Endpoint - Leave empty for real AWS DynamoDB
# DYNAMODB_ENDPOINT=

# DynamoDB Table Names
TEMPLES_TABLE=Prod-Temples
ARTIFACTS_TABLE=Prod-Artifacts
TEMPLE_GROUPS_TABLE=Prod-TempleGroups
PRICING_TABLE=Prod-Pricing
PRICE_HISTORY_TABLE=Prod-PriceHistory
PRICING_FORMULAS_TABLE=Prod-PricingFormulas
CONTENT_JOBS_TABLE=Prod-ContentJobs
CONTENT_TABLE=Prod-Content
ADMIN_USERS_TABLE=Prod-AdminUsers
MOBILE_USERS_TABLE=Prod-MobileUsers
DEFECTS_TABLE=Prod-Defects
STATE_VISIBILITY_TABLE=Prod-StateVisibility

# S3 Bucket Names
CONTENT_BUCKET=prod-sanaathana-content
ASSETS_BUCKET=prod-sanaathana-assets

# API Configuration
API_URL=https://api.sanaathana.org
ADMIN_PORTAL_URL=https://admin.sanaathana.org
MOBILE_APP_URL=https://app.sanaathana.org

# Feature Flags
ENABLE_AI_CONTENT_GENERATION=true
ENABLE_ANALYTICS=true
ENABLE_CACHING=true

# Logging
LOG_LEVEL=warn
