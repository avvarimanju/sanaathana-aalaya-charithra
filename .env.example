# ============================================================================
# Environment Configuration Template
# Copy this file to .env.development, .env.staging, or .env.production
# ============================================================================

# Environment name (development, staging, production)
NODE_ENV=development

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id

# DynamoDB Endpoint (only set for local development with LocalStack)
# Leave empty for staging/production to use real AWS DynamoDB
DYNAMODB_ENDPOINT=http://localhost:4566

# DynamoDB Table Names (use different names per environment)
TEMPLES_TABLE=Dev-Temples
ARTIFACTS_TABLE=Dev-Artifacts
TEMPLE_GROUPS_TABLE=Dev-TempleGroups
PRICING_TABLE=Dev-Pricing
PRICE_HISTORY_TABLE=Dev-PriceHistory
PRICING_FORMULAS_TABLE=Dev-PricingFormulas
CONTENT_JOBS_TABLE=Dev-ContentJobs
CONTENT_TABLE=Dev-Content
ADMIN_USERS_TABLE=Dev-AdminUsers
MOBILE_USERS_TABLE=Dev-MobileUsers
DEFECTS_TABLE=Dev-Defects
STATE_VISIBILITY_TABLE=Dev-StateVisibility

# S3 Bucket Names
CONTENT_BUCKET=dev-sanaathana-content
ASSETS_BUCKET=dev-sanaathana-assets

# API Configuration
API_URL=http://localhost:4000
ADMIN_PORTAL_URL=http://localhost:5173
MOBILE_APP_URL=http://localhost:8081

# Feature Flags
ENABLE_AI_CONTENT_GENERATION=false
ENABLE_ANALYTICS=false
ENABLE_CACHING=true

# Logging
LOG_LEVEL=debug

# ============================================================================
# IMPORTANT: Never commit actual credentials to version control!
# Use AWS Secrets Manager or environment variables for sensitive data
# ============================================================================
